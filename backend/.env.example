# Backend Environment Variables
# Copy this file to .env and fill in your values

# Supabase Configuration (required)
# Project URL: Supabase dashboard > Settings > API > Project URL
SUPABASE_URL=

# Service Role Key (keep this SECRET — never expose to frontend!)
# Supabase dashboard > Settings > API > service_role key
SUPABASE_SERVICE_KEY=

# JWT Secret for verifying Supabase tokens
# Supabase dashboard > Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=

# Hugging Face Inference API (required for AI analysis)
# Get at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Sentry Error Tracking (optional)
# Get DSN at: https://sentry.io > Settings > Projects > Client Keys
SENTRY_DSN=

# CORS — comma-separated list of allowed frontend origins
# e.g.: http://localhost:3000,https://auranode.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# Maximum file upload size in megabytes (default: 10)
MAX_FILE_SIZE_MB=10

# Environment: development | production
ENVIRONMENT=development
